      }
    },
    "gold_tier_recovery": {
      "command": "python",
      "args": ["-m", "mcp_servers.recovery_mcp"],
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      }
    }
  }
}
