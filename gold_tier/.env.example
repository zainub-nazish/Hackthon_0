# Gold Tier Autonomous Employee — Environment Variables
# Copy to .env and fill in real values. NEVER commit .env to git.

# ── Anthropic ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── X (Twitter) API v2 ────────────────────────────────────────────
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=
TWITTER_BEARER_TOKEN=

# ── Facebook / Instagram Graph API ───────────────────────────────
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_PAGE_ACCESS_TOKEN=
FACEBOOK_PAGE_ID=
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_ACCOUNT_ID=

# ── Notifications (optional) ─────────────────────────────────────
SLACK_WEBHOOK_URL=
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_USER=
EMAIL_PASSWORD=
CEO_EMAIL=

# ── Database Configuration ────────────────────────────────────────
ACCOUNTING_DB_PATH=data/accounting.db
TASKS_DB_PATH=data/tasks.db
AUDIT_DB_PATH=data/audit.db

# ── Logging Configuration ─────────────────────────────────────────
LOG_DIR=logs
LOG_LEVEL=INFO

# ── MCP Server Configuration ──────────────────────────────────────
MCP_TIMEOUT=30
MCP_MAX_RETRIES=3

# ── Autonomous Agent Configuration ────────────────────────────────
MAX_ITERATIONS=10
TASK_TIMEOUT=300
DRY_RUN_MODE=true

# ── Scheduling Configuration ──────────────────────────────────────
# Weekly audit schedule (cron format: minute hour day-of-month month day-of-week)
AUDIT_SCHEDULE_CRON=0 9 * * 1
SOCIAL_POST_INTERVAL_HOURS=24

# ── Security Configuration ────────────────────────────────────────
ENABLE_RATE_LIMITING=true
MAX_API_CALLS_PER_HOUR=100

# ══════════════════════════════════════════════════════════════════
# SECURITY BEST PRACTICES
# ══════════════════════════════════════════════════════════════════
#
# 1. NEVER commit .env file to version control
# 2. Add .env to .gitignore immediately
# 3. Use different credentials for dev/staging/production
# 4. Rotate credentials regularly (every 90 days minimum)
# 5. Use least-privilege access for all API tokens
# 6. Enable 2FA on all social media accounts
# 7. Monitor API usage and set up alerts
# 8. Store production secrets in secure vault (AWS Secrets Manager, etc.)
# 9. Review and revoke unused API tokens regularly
# 10. Use environment-specific files (.env.production, .env.staging)
#
# ══════════════════════════════════════════════════════════════════

