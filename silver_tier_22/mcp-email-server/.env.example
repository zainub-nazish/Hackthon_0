# ── Option A: JSON credentials file (recommended) ────────────────────────────
# Place this file at ~/ai-secrets/gmail_credentials.json
# Then point GMAIL_CREDENTIALS to it in mcp.json (see below).
#
# File format (gmail_credentials.json):
# {
#   "client_id":     "your-client-id.apps.googleusercontent.com",
#   "client_secret": "GOCSPX-your-client-secret",
#   "refresh_token": "1//your-refresh-token",
#   "user":          "you@gmail.com"
# }
#
# mcp.json entry:
# {
#   "mcpServers": {
#     "email": {
#       "command": "node",
#       "args": ["/home/zainab/mcp-email-server/dist/index.js"],
#       "env": { "GMAIL_CREDENTIALS": "/home/zainab/ai-secrets/gmail_credentials.json" }
#     }
#   }
# }

# ── Option B: individual env vars (flat .env) ─────────────────────────────────
# Place this file at ~/ai-secrets/.env  (loaded automatically as fallback)

GMAIL_USER=you@gmail.com
GMAIL_CLIENT_ID=your-client-id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=GOCSPX-your-client-secret
GMAIL_REFRESH_TOKEN=1//your-refresh-token

# ── How to get these values ───────────────────────────────────────────────────
# 1. https://console.cloud.google.com → APIs & Services → Credentials
# 2. Create OAuth 2.0 Client ID (Desktop app)
# 3. Enable Gmail API for the project
# 4. Go to https://developers.google.com/oauthplayground
#    - Gear icon → check "Use your own OAuth credentials" → paste Client ID + Secret
#    - Authorise scope: https://mail.google.com/
#    - Exchange auth code for tokens → copy Refresh Token
